{
  "expo": {
    "name": "CycloTrack",
    "slug": "cyclotrack",
    "scheme": "cyclotrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "CycloTrack utilise votre position GPS pour enregistrer votre parcours.",
        "NSLocationAlwaysUsageDescription": "CycloTrack utilise votre position GPS en arrière-plan pendant la sortie.",
        "NSBluetoothAlwaysUsageDescription": "CycloTrack utilise le Bluetooth pour se connecter à vos capteurs de puissance et de fréquence cardiaque."
      }
    },
    "android": {
      "package": "com.cyclotrack.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "cyclotrack" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "BLUETOOTH",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "react-native-ble-plx",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "CycloTrack utilise votre position GPS pour enregistrer votre parcours vélo."
        }
      ]
    ]
  }
}
